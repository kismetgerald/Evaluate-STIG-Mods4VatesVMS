   -a always,exit -F arch=b64 -S open,openat,creat,truncate,ftruncate -F exit=-EACCES -F auid&gt;=1000 -F auid!=4294967295 -k access
   -a always,exit -F arch=b64 -S open,openat,creat,truncate,ftruncate -F exit=-EPERM -F auid&gt;=1000 -F auid!=4294967295 -k access
