					<ATTRIBUTE_DATA>Verify the VMM monitors remote access methods automatically. If it does not, this is a finding.</ATTRIBUTE_DATA>
				</STIG_DATA>
				<STIG_DATA>
					<VULN_ATTRIBUTE>Fix_Text</VULN_ATTRIBUTE>
					<ATTRIBUTE_DATA>Configure the VMM to monitor remote access methods automatically.</ATTRIBUTE_DATA>
				</STIG_DATA>
