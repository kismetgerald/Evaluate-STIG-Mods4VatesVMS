        $FindingDetails += "Result: " + $(if ($pamCheckStr -ne "") { $pamCheckStr } else { "(none found)" }) + $nl + $nl
    }

    if ($pkcs11Str -match "pam_pkcs11 is enabled" -or $pamCheckStr -match "pam_pkcs11") {
